<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forkhead Yazar Paneli</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: #fff; margin: 0; padding: 10px; color: #333; }
        .header { text-align: center; margin-bottom: 15px; border-bottom: 2px solid #ff9800; padding-bottom: 10px; }
        h2 { margin: 5px 0; color: #1a1a1a; font-size: 1.2rem; }
        
        .toplam-kutu {
            background-color: #0A1128;
            color: #ffa000;
            font-size: 24px;
            font-weight: bold;
            text-align: center;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        /* Apple ve mobil cihazlar için taşıyıcı kutu */
        .table-container {
            width: 100%;
            overflow-x: auto;
            /* iOS'ta kaydırmanın yağ gibi akmasını sağlar */
            -webkit-overflow-scrolling: touch; 
            border-radius: 4px;
        }

        table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 12px; }
        th, td { 
            border: 1px solid #ddd; 
            padding: 10px 8px; 
            text-align: center; 
            /* Yazıların alt satıra inip ezilmesini kesin olarak yasaklar */
            white-space: nowrap; 
        }
        th { background-color: #1a1a1a; color: white; font-weight: bold; }
        tr:nth-child(even) { background-color: #fcfcfc; }
        .error { color: red; text-align: center; margin-top: 30px; font-weight: bold; }
        .loading { text-align: center; margin-top: 30px; font-style: italic; color: #666; }
    </style>
</head>
<body>
    <div class="header">
        <h2>Mr. Forkhead Yayıncılık</h2>
        <small>Yazar Satış İstatistikleri</small>
    </div>
    
    <div id="toplam-alani"></div>
    
    <div id="content">
        <div class="loading">Veriler Yükleniyor...</div>
    </div>

    <script>
        // GOOGLE TABLO'DAN ALDIĞIN CSV LİNKİNİ BURAYA YAPIŞTIR
        const csvUrl = "https://docs.google.com/spreadsheets/d/e/2PACX-1vSKxcLVGnMYuLIWPfURRcgPieontqhuhF4lmKC5LNtG8tTxw0RlWZVceHivhaNmq0awB3t80JdWwGxn/pub?gid=594982577&single=true&output=csv";

        const toplanacakSutunIndex = 9; 

        function getParam(name) {
            const urlParams = new URLSearchParams(window.location.search);
            return urlParams.get(name);
        }

        function parseCSVLine(line) {
            const result = [];
            let curVal = "";
            let inQuotes = false;
            for (let i = 0; i < line.length; i++) {
                const char = line[i];
                if (char === '"') {
                    inQuotes = !inQuotes;
                } else if (char === ',' && !inQuotes) {
                    result.push(curVal.trim());
                    curVal = "";
                } else {
                    curVal += char;
                }
            }
            result.push(curVal.trim());
            return result.map(v => v.replace(/^"|"$/g, ''));
        }

        async function fetchStats() {
            const userEmail = getParam('yazar_maili')?.toLowerCase().trim();
            if (!userEmail) {
                document.getElementById('content').innerHTML = '<div class="error">Yetkisiz Erişim: Mail adresi eksik.</div>';
                return;
            }

            try {
                const response = await fetch(csvUrl);
                const text = await response.text();
                const lines = text.split(/\r?\n/).filter(line => line.trim() !== "");
                const rows = lines.map(line => parseCSVLine(line));
                
                if (rows.length < 1) throw new Error("Boş veri");

                // Tabloyu sarmalayan yeni div eklendi
                let html = '<div class="table-container"><table><thead><tr>';
                for (let i = 2; i < rows[0].length; i++) {
                    html += `<th>${rows[0][i]}</th>`;
                }
                html += '</tr></thead><tbody>';

                let found = false;
                let toplamSayi = 0;

                for (let j = 1; j < rows.length; j++) {
                    if (rows[j][1]?.toLowerCase() === userEmail) {
                        found = true;
                        html += '<tr>';
                        for (let k = 2; k < rows[j].length; k++) {
                            let hucreDegeri = rows[j][k] || "-";
                            html += `<td>${hucreDegeri}</td>`;
                            
                            if (k === toplanacakSutunIndex && hucreDegeri !== "-") {
                                let temizSayi = hucreDegeri.replace(/\./g, "").replace(",", ".");
                                toplamSayi += parseFloat(temizSayi) || 0;
                            }
                        }
                        html += '</tr>';
                    }
                }
                html += '</tbody></table></div>';

                if (!found) {
                    document.getElementById('content').innerHTML = '<div class="error">Kayıtlı veri bulunamadı.</div>';
                } else {
                    let formatliPara = new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(toplamSayi);
                    document.getElementById('toplam-alani').innerHTML = `<div class="toplam-kutu">Toplam: ${formatliPara}</div>`;
                    document.getElementById('content').innerHTML = html;
                }
            } catch (err) {
                document.getElementById('content').innerHTML = '<div class="error">Bağlantı Hatası: Veriler çekilemedi.</div>';
            }
        }

        fetchStats();
    </script>
</body>
</html>
